{
  "extends": [
    "next/core-web-vitals",
    "next/typescript",
    "prettier",
    "plugin:@tanstack/query/recommended"
  ],
  "ignorePatterns": ["**/node_modules/*", "**/.next/*", "**/public/*"],
  "rules": {
    "indent": ["error", 2],
    "quotes": ["error", "double"],
    "semi": ["error", "always"]
  }
}
